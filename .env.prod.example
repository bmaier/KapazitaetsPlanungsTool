# BorderCapControl — Produktions-Umgebungsvariablen Template
#
# ANLEITUNG:
#   cp .env.prod.example .env.prod
#   # Alle Felder ohne Default-Wert MÜSSEN befüllt werden
#   # .env.prod NIEMALS in Git einchecken (steht in .gitignore)
#
# VERWENDUNG:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env.prod up -d

# ---------------------------------------------------------------------------
# PostgreSQL — Haupt-Datenbankzugang (Superuser, nur für Migrations/Init)
# ---------------------------------------------------------------------------
POSTGRES_DB=bordercap
POSTGRES_USER=bordercap
POSTGRES_PASSWORD=                      # PFLICHTFELD — darf nicht leer bleiben

# Non-Superuser für Applikation (nur app_role — kein SUPERUSER)
POSTGRES_APP_USER=bordercap_app
POSTGRES_APP_PASSWORD=                  # PFLICHTFELD — darf nicht leer bleiben

# ---------------------------------------------------------------------------
# Backend — Datenbankverbindung (asyncpg-Format)
# Verwendet bordercap_app (Non-Superuser), nicht den Superuser!
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://bordercap_app:CHANGE_ME@postgres:5432/bordercap

# ---------------------------------------------------------------------------
# Keycloak — Admin-Zugang
# ---------------------------------------------------------------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=               # PFLICHTFELD — darf nicht leer bleiben

# ---------------------------------------------------------------------------
# Keycloak — Öffentliche URL (PFLICHTFELD)
#
# WICHTIG: Muss exakt der URL entsprechen, unter der Keycloak vom Browser
# erreichbar ist (nach Reverse-Proxy-Weiterleitung).
#
# Beispiele:
#   https://bordercap.behoerde.de          (wenn Reverse Proxy Keycloak-Pfade weiterleitet)
#   https://auth.behoerde.de               (wenn Keycloak auf eigener Subdomain)
#   http://192.168.1.100:8080              (interne IP ohne TLS, nur für Testumgebungen)
# ---------------------------------------------------------------------------
KEYCLOAK_PUBLIC_URL=                    # PFLICHTFELD — z.B. https://bordercap.behoerde.de

# Interne Keycloak-URL (Docker-intern, kein Reverse Proxy)
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=bordercapcontrol
KEYCLOAK_CLIENT_ID=bordercapcontrol-frontend

# ---------------------------------------------------------------------------
# Frontend
# ---------------------------------------------------------------------------
# Port auf dem der Nginx-Container nach außen erreichbar ist.
# Der Reverse Proxy leitet auf diesen Port weiter.
FRONTEND_PORT=80

# URL des internen Support-Portals (optional — leer lassen um Button auszublenden)
# VITE_SUPPORT_URL=https://support.intern.behoerde.de

# ---------------------------------------------------------------------------
# Keycloak SMTP — E-Mail-Versand (Passwort-Onboarding, Passwort-Reset)
#
# SMTP muss in der Keycloak Admin-UI unter Realm Settings → E-Mail eingetragen
# werden. Diese Variablen sind NICHT direkt an Keycloak übergeben — sie dienen
# als Gedächtnisstütze für den Betreiber.
#
# Nach dem ersten Start:
#   1. Keycloak Admin-UI aufrufen: ${KEYCLOAK_PUBLIC_URL}/admin
#   2. Realm "bordercapcontrol" → Realm Settings → E-Mail
#   3. SMTP-Daten eintragen (Host, Port, From-Adresse, ggf. Auth)
#
# Alternativ: infra/keycloak/setup-prod-realm.sh ausführen
#
# Beispiel Office 365 / Exchange Online:
# KC_SMTP_HOST=smtp.office365.com
# KC_SMTP_PORT=587
# KC_SMTP_FROM=noreply@behoerde.de
# KC_SMTP_FROM_DISPLAY=BorderCapControl
# KC_SMTP_USER=noreply@behoerde.de
# KC_SMTP_PASSWORD=
# KC_SMTP_STARTTLS=true
# KC_SMTP_SSL=false
#
# Beispiel interner SMTP-Relay (kein Auth):
# KC_SMTP_HOST=mail.intern.local
# KC_SMTP_PORT=25
# KC_SMTP_FROM=noreply@bordercapcontrol.intern
# KC_SMTP_FROM_DISPLAY=BorderCapControl
# KC_SMTP_USER=
# KC_SMTP_PASSWORD=
# KC_SMTP_STARTTLS=false
# KC_SMTP_SSL=false
