Feature: Bettsuche — SuggestionWizard # features/suggestion_wizard.feature:1
  Als Sachbearbeiter einer Einrichtung
  möchte ich für eine Person alle freien Betten an allen aktiven Einrichtungen sehen,
  damit ich das passende Bett gezielt auswählen kann.
  Background:   # features/suggestion_wizard.feature:6

  Scenario: Einzelperson-Suche liefert jedes freie Bett als eigene Variante                                      # features/suggestion_wizard.feature:15
    Given die API läuft auf http://localhost:8000                                                                # steps/capacity_steps.py:76
    And die Datenbank ist leer (Suggestion-Test-Isolation)                                                       # steps/suggestion_steps.py:87
    And eine Einrichtung "Quelle" mit ID "src-loc" existiert mit 0 freien Betten                                 # steps/suggestion_steps.py:108
    And eine Einrichtung "Ziel-A" mit ID "dst-a" existiert mit 3 freien Männerbetten                             # steps/suggestion_steps.py:118
    And eine Einrichtung "Ziel-B" mit ID "dst-b" existiert mit 5 freien Männerbetten                             # steps/suggestion_steps.py:118
    When ich POST /api/suggestions sende als Einrichtung "src-loc" mit anzahl=1 geschlecht=M cross_location=true # steps/suggestion_steps.py:140
    Then ist der HTTP-Status 200                                                                                 # steps/capacity_steps.py:304
    And die Antwort enthält genau 8 Varianten                                                                    # steps/suggestion_steps.py:174
    And jede Variante enthält genau 1 Bett                                                                       # steps/suggestion_steps.py:183

  Scenario: Pro Zieleinrichtung werden alle freien Betten zurückgegeben                                          # features/suggestion_wizard.feature:21
    Given die API läuft auf http://localhost:8000                                                                # steps/capacity_steps.py:76
    And die Datenbank ist leer (Suggestion-Test-Isolation)                                                       # steps/suggestion_steps.py:87
    And eine Einrichtung "Quelle" mit ID "src-loc" existiert mit 0 freien Betten                                 # steps/suggestion_steps.py:108
    And eine Einrichtung "Ziel-A" mit ID "dst-a" existiert mit 3 freien Männerbetten                             # steps/suggestion_steps.py:118
    And eine Einrichtung "Ziel-B" mit ID "dst-b" existiert mit 5 freien Männerbetten                             # steps/suggestion_steps.py:118
    When ich POST /api/suggestions sende als Einrichtung "src-loc" mit anzahl=1 geschlecht=M cross_location=true # steps/suggestion_steps.py:140
    Then ist der HTTP-Status 200                                                                                 # steps/capacity_steps.py:304
    And die Einrichtung "Ziel-A" ist in 3 Varianten vertreten                                                    # steps/suggestion_steps.py:192
    And die Einrichtung "Ziel-B" ist in 5 Varianten vertreten                                                    # steps/suggestion_steps.py:192

  Scenario: Einrichtung ohne freie Betten erscheint nicht in Varianten                                           # features/suggestion_wizard.feature:27
    Given die API läuft auf http://localhost:8000                                                                # steps/capacity_steps.py:76
    And die Datenbank ist leer (Suggestion-Test-Isolation)                                                       # steps/suggestion_steps.py:87
    And eine Einrichtung "Quelle" mit ID "src-loc" existiert mit 0 freien Betten                                 # steps/suggestion_steps.py:108
    And eine Einrichtung "Ziel-A" mit ID "dst-a" existiert mit 3 freien Männerbetten                             # steps/suggestion_steps.py:118
    And eine Einrichtung "Ziel-B" mit ID "dst-b" existiert mit 5 freien Männerbetten                             # steps/suggestion_steps.py:118
    When ich POST /api/suggestions sende als Einrichtung "src-loc" mit anzahl=1 geschlecht=M cross_location=true # steps/suggestion_steps.py:140
    Then ist der HTTP-Status 200                                                                                 # steps/capacity_steps.py:304
    And die Einrichtung "Quelle" erscheint nicht in den Varianten                                                # steps/suggestion_steps.py:205

  Scenario: Frauensuche liefert keine Männer-Betten                                                              # features/suggestion_wizard.feature:34
    Given die API läuft auf http://localhost:8000                                                                # steps/capacity_steps.py:76
    And die Datenbank ist leer (Suggestion-Test-Isolation)                                                       # steps/suggestion_steps.py:87
    And eine Einrichtung "Quelle" mit ID "src-loc" existiert mit 0 freien Betten                                 # steps/suggestion_steps.py:108
    And eine Einrichtung "Ziel-A" mit ID "dst-a" existiert mit 3 freien Männerbetten                             # steps/suggestion_steps.py:118
    And eine Einrichtung "Ziel-B" mit ID "dst-b" existiert mit 5 freien Männerbetten                             # steps/suggestion_steps.py:118
    Given eine Einrichtung "Ziel-C" mit ID "dst-c" existiert mit 2 freien Frauenbetten                           # steps/suggestion_steps.py:128
    When ich POST /api/suggestions sende als Einrichtung "src-loc" mit anzahl=1 geschlecht=W cross_location=true # steps/suggestion_steps.py:140
    Then ist der HTTP-Status 200                                                                                 # steps/capacity_steps.py:304
    And alle Varianten gehören zu Frauenräumen                                                                   # steps/suggestion_steps.py:216
    And die Einrichtung "Ziel-A" erscheint nicht in den Varianten                                                # steps/suggestion_steps.py:205

  Scenario: Lokale Suche (cross_location=false) liefert nur eigene Einrichtung                                      # features/suggestion_wizard.feature:43
    Given die API läuft auf http://localhost:8000                                                                   # steps/capacity_steps.py:76
    And die Datenbank ist leer (Suggestion-Test-Isolation)                                                          # steps/suggestion_steps.py:87
    And eine Einrichtung "Quelle" mit ID "src-loc" existiert mit 0 freien Betten                                    # steps/suggestion_steps.py:108
    And eine Einrichtung "Ziel-A" mit ID "dst-a" existiert mit 3 freien Männerbetten                                # steps/suggestion_steps.py:118
    And eine Einrichtung "Ziel-B" mit ID "dst-b" existiert mit 5 freien Männerbetten                                # steps/suggestion_steps.py:118
    Given eine Einrichtung "Lokal" mit ID "local-loc" existiert mit 4 freien Männerbetten                           # steps/suggestion_steps.py:118
    When ich POST /api/suggestions sende als Einrichtung "local-loc" mit anzahl=1 geschlecht=M cross_location=false # steps/suggestion_steps.py:140
    Then ist der HTTP-Status 200                                                                                    # steps/capacity_steps.py:304
    And alle Varianten gehören zur Einrichtung "Lokal"                                                              # steps/suggestion_steps.py:230

  Scenario: Gruppen-Suche gibt pro Einrichtung maximal 2 kompakte Varianten zurück                               # features/suggestion_wizard.feature:51
    Given die API läuft auf http://localhost:8000                                                                # steps/capacity_steps.py:76
    And die Datenbank ist leer (Suggestion-Test-Isolation)                                                       # steps/suggestion_steps.py:87
    And eine Einrichtung "Quelle" mit ID "src-loc" existiert mit 0 freien Betten                                 # steps/suggestion_steps.py:108
    And eine Einrichtung "Ziel-A" mit ID "dst-a" existiert mit 3 freien Männerbetten                             # steps/suggestion_steps.py:118
    And eine Einrichtung "Ziel-B" mit ID "dst-b" existiert mit 5 freien Männerbetten                             # steps/suggestion_steps.py:118
    When ich POST /api/suggestions sende als Einrichtung "src-loc" mit anzahl=2 geschlecht=M cross_location=true # steps/suggestion_steps.py:140
    Then ist der HTTP-Status 200                                                                                 # steps/capacity_steps.py:304
    And die Einrichtung "Ziel-B" ist in maximal 2 Varianten vertreten                                            # steps/suggestion_steps.py:241
    And jede Variante enthält genau 2 Betten                                                                     # steps/suggestion_steps.py:252

