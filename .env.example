# BorderCapControl — Umgebungsvariablen Template
# Kopiere diese Datei nach .env und passe die Werte an.
# NIEMALS .env in Git einchecken! (steht in .gitignore)

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_DB=bordercap
POSTGRES_USER=bordercap
POSTGRES_PASSWORD=bordercap_dev
# Non-Superuser für Applikation und Tests (hat nur app_role, kein SUPERUSER)
POSTGRES_APP_USER=bordercap_app
POSTGRES_APP_PASSWORD=bordercap_app_dev

# ---------------------------------------------------------------------------
# Backend — DB-Verbindung (asyncpg-Format)
# Für lokale Entwicklung außerhalb Docker: postgres durch localhost ersetzen
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://bordercap:bordercap_dev@localhost:5432/bordercap

# ---------------------------------------------------------------------------
# Keycloak
# ---------------------------------------------------------------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin_dev
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=bordercapcontrol
KEYCLOAK_CLIENT_ID=bordercapcontrol-frontend

# ---------------------------------------------------------------------------
# Keycloak Public URL — öffentliche URL wie der BROWSER Keycloak erreicht
# ---------------------------------------------------------------------------
# Lokal (Dev):   http://localhost:8080   ← Default, kein Eintrag nötig
# Prod (IP):     http://192.168.1.100:8080
# Prod (Domain): https://auth.meine-domain.de
#
# WICHTIG: Muss mit dem Port übereinstimmen, der in docker-compose.override.yml
# für Keycloak nach außen gemappt ist (Standard: 8080).
# Wenn diese Variable fehlt oder auf localhost steht, schlagen Logins auf
# Remote-Servern fehl — Keycloak redirected den Browser zu localhost.
KEYCLOAK_PUBLIC_URL=http://localhost:8080

# ---------------------------------------------------------------------------
# Keycloak SMTP — E-Mail-Versand für Passwort-Onboarding und Reset
# ---------------------------------------------------------------------------
# DEV: Kein Eintrag nötig — Mailpit (http://localhost:8025) fängt alle Mails ab.
#      SMTP ist in infra/keycloak/realm-export.json auf mailpit:1025 voreingestellt.
#
# PROD: Werte unten anpassen und in KC Admin-UI unter
#       Realm Settings → E-Mail eintragen ODER die KC_SMTP_*-Variablen setzen,
#       damit docker-compose.yml sie an den Keycloak-Container weitergibt.
#
# Beispiel für Office 365 / Exchange Online:
# KC_SMTP_HOST=smtp.office365.com
# KC_SMTP_PORT=587
# KC_SMTP_FROM=noreply@ihre-behoerde.de
# KC_SMTP_FROM_DISPLAY=BorderCapControl
# KC_SMTP_USER=noreply@ihre-behoerde.de
# KC_SMTP_PASSWORD=IhrSMTP-Passwort
# KC_SMTP_STARTTLS=true
# KC_SMTP_SSL=false
#
# Beispiel für lokalen/internen SMTP-Relay (kein Auth):
# KC_SMTP_HOST=mail.intern.local
# KC_SMTP_PORT=25
# KC_SMTP_FROM=noreply@bordercapcontrol.intern
# KC_SMTP_FROM_DISPLAY=BorderCapControl
# KC_SMTP_USER=
# KC_SMTP_PASSWORD=
# KC_SMTP_STARTTLS=false
# KC_SMTP_SSL=false

# ---------------------------------------------------------------------------
# Frontend — Support-Portal URL (konfigurierbar je Deployment)
# ---------------------------------------------------------------------------
# URL des BAMF-internen Support-Portals. Wird im NavBar als Support-Link angezeigt.
# Leer lassen um den Support-Button auszublenden.
# VITE_SUPPORT_URL=https://support.intern.bamf.de
